<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A2E">

    <!-- Top Bar: Name + Timer + End -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoomId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calling…"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Call timer -->
            <TextView
                android:id="@+id/tvCallTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FF4CAF50"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="#FF4CAF50"
                android:textSize="11sp"
                android:visibility="gone"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="End Call"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:backgroundTint="#FFF44336"/>
    </LinearLayout>

    <!-- Participant Tiles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <!-- You -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/participant_bg"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvMicIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤"
                android:textSize="28sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvYourLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Them -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/participant_bg">

            <TextView
                android:id="@+id/tvSpeakerIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="28sp"/>

            <TextView
                android:id="@+id/tvCalleeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Them"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvTheirLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connecting…"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"/>

        <!-- Reconnect indicator -->
        <TextView
            android:id="@+id/tvReconnecting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⟳ Reconnecting…"
            android:textColor="#FFFFC107"
            android:textSize="11sp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Transcript Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#FF16213E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Live Transcript"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- Speaking animation indicator -->
                <TextView
                    android:id="@+id/tvSpeakingDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●●●"
                    android:textColor="#FF4CAF50"
                    android:textSize="10sp"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="They said:"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:minHeight="44dp"
                android:layout_marginBottom="14dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Translation (your language):"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTranslated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FF9C27B0"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls: Mute | Speaker | End -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="32dp"
        android:paddingHorizontal="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMute"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="🎤 Mute"
            android:textSize="12sp"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/purple_500"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeaker"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="🔈 Speaker"
            android:textSize="12sp"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/purple_500"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndCall2"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="📵 End"
            android:textSize="12sp"
            app:cornerRadius="26dp"
            app:backgroundTint="#FFF44336"/>
    </LinearLayout>

</LinearLayout>
